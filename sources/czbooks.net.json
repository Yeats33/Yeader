        { "key": "favorite", "label": "收藏榜", "group": "排行榜" },
        { "key": "finish", "label": "完本榜", "group": "排行榜" },
        { "key": "hot", "label": "工口榜", "group": "排行榜" }
      ],
      "capabilities": [
        {
          "kind": "search",
          "request": {
            "url": "https://czbooks.net/s/{{key}}?q={{key}}",
            "method": "GET"
          },
          "item": {
            "engine": "css",
            "query": "ul.novel-list li.novel-item-wrapper"
          },
          "fields": {
            "name": { "engine": "css", "query": ".novel-item-title" },
            "author": { "engine": "css", "query": ".novel-item-author a" },
            "bookUrl": { "engine": "css", "query": ".novel-item-cover-wrapper a", "output": "href" },
            "coverUrl": { "engine": "css", "query": ".novel-item-thumbnail img", "output": "src" },
            "lastChapter": { "engine": "css", "query": ".novel-item-newest-chapter a" },
            "kind": { "engine": "css", "query": ".novel-item-state" }
          }
        },
        {
          "kind": "detail",
          "request": {
            "url": "{{bookUrl}}"
          },
          "item": {
            "engine": "css",
            "query": ".novel-detail"
          },
          "fields": {
            "name": { "engine": "css", "query": ".info-wrap .title" },
            "author": { "engine": "css", "query": ".info .author a" },
            "coverUrl": { "engine": "css", "query": ".thumbnail img", "output": "src" },
            "intro": { "engine": "css", "query": ".description" },
            "kind": { "engine": "css", "query": "#novel-category" }
          }
        },
        {
          "kind": "toc",
          "request": {
            "url": "{{bookUrl}}"
          },
          "item": {
            "engine": "css",
            "query": "#chapter-list li a"
          },
          "fields": {
            "chapterName": { "engine": "text", "query": "" },
            "chapterUrl": { "engine": "css", "query": "", "output": "href" }
          }
        },
        {
          "kind": "content",
          "request": {
            "url": "{{chapterUrl}}"
          },
          "fields": {
            "title": { "engine": "css", "query": ".chapter-detail .name" },
            "content": { "engine": "css", "query": ".chapter-detail .content", "output": "html" },
            "nextContentUrl": { "engine": "css", "query": "a.next-chapter", "output": "href" }
          }
        },
        {
          "kind": "list",
          "request": {
            "url": "https://czbooks.net/c/{{category}}{{order}}"
          },
          "item": {
            "engine": "css",
            "query": "ul.novel-list li.novel-item-wrapper"
          },
          "fields": {
            "name": { "engine": "css", "query": ".novel-item-title" },
            "author": { "engine": "css", "query": ".novel-item-author a" },
            "bookUrl": { "engine": "css", "query": ".novel-item-cover-wrapper a", "output": "href" },
            "coverUrl": { "engine": "css", "query": ".novel-item-thumbnail img", "output": "src" },
            "lastChapter": { "engine": "css", "query": ".novel-item-newest-chapter a" },
            "kind": { "engine": "css", "query": ".novel-item-state" }
          }
        }
      ]
    }
  ]
